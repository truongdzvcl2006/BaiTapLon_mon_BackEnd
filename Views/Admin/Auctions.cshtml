<!-- Views/Admin/Auctions.cshtml -->
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý đấu giá";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Quản lý đấu giá</h1>
        <button class="btn btn-primary" onclick="openAddAuctionModal()">
            <i class="fas fa-plus"></i> Tạo phiên đấu giá
        </button>
    </div>

    <!-- Thống kê nhanh -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="admin-card">
                <div class="admin-card-icon bg-primary">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="admin-card-content">
                    <h3>5</h3>
                    <p>Sắp diễn ra</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-card">
                <div class="admin-card-icon bg-success">
                    <i class="fas fa-play"></i>
                </div>
                <div class="admin-card-content">
                    <h3>3</h3>
                    <p>Đang diễn ra</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-card">
                <div class="admin-card-icon bg-warning">
                    <i class="fas fa-hourglass-end"></i>
                </div>
                <div class="admin-card-content">
                    <h3>12</h3>
                    <p>Đã kết thúc</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-card">
                <div class="admin-card-icon bg-info">
                    <i class="fas fa-money-bill"></i>
                </div>
                <div class="admin-card-content">
                    <h3>2.5B</h3>
                    <p>Tổng giá trị</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Danh sách đấu giá -->
    <div class="admin-card">
        <ul class="nav nav-tabs mb-3">
            <li class="nav-item">
                <a class="nav-link active" data-bs-toggle="tab" href="#all">Tất cả</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#upcoming">Sắp diễn ra</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#ongoing">Đang diễn ra</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#ended">Đã kết thúc</a>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane active" id="all">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Bất động sản</th>
                                <th>Giá khởi điểm</th>
                                <th>Giá hiện tại</th>
                                <th>Bắt đầu</th>
                                <th>Kết thúc</th>
                                <th>Trạng thái</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>1</td>
                                <td>Căn hộ Vinhomes Q9</td>
                                <td>3.5 tỷ</td>
                                <td>3.8 tỷ</td>
                                <td>20/03/2026 09:00</td>
                                <td>27/03/2026 09:00</td>
                                <td><span class="badge bg-success">Đang diễn ra</span></td>
                                <td>
                                    <button class="btn btn-sm btn-info"><i class="fas fa-eye"></i></button>
                                    <button class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></button>
                                    <button class="btn btn-sm btn-danger"><i class="fas fa-stop"></i></button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>